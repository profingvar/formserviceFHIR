# ============================================================
# sso.pdhc — Environment Configuration
# ============================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://sso_user:sso_password@localhost:9003/sso_db

# --- JWT ---
SESSION_EXPIRY_HOURS=24

# --- Bootstrap Superuser (first deployment only) ---
BOOTSTRAP_SU_EMAIL=admin@example.com
BOOTSTRAP_SU_PASSWORD=change-me-minimum-8-chars

# --- SSO Handshake ---
# Comma-separated origins allowed for CORS and SSO redirect
ALLOWED_ORIGINS=http://localhost:9000
# Comma-separated exact callback URLs for SSO handshake redirect
ALLOWED_CALLBACK_URLS=http://localhost:9000/callback

# --- Service Credentials (one pair per downstream service) ---
# SSO_CLIENT_ID_SERVICENAME=client-id-here
# SSO_CLIENT_SECRET_SERVICENAME=client-secret-here

# --- API Key Metadata ---
KEY_CREATED_AT=2026-03-18T00:00:00Z

# --- Logging ---
LOG_DIR=./logs
